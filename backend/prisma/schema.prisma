generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  category    String
  description String
  duration    String
  priceType   String
  basePrice   Int?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  bookings    Booking[]
}

model WashPricing {
  id           String @id @default(cuid())
  package      String
  vehicleType  String
  priceInPaise Int
}

model TimeSlot {
  id       String    @id @default(cuid())
  date     DateTime  @db.Date
  time     String
  isBooked Boolean   @default(false)
  bookings Booking[]
}

model Booking {
  id                   String   @id @default(cuid())
  reference            String   @unique
  serviceId            String
  service              Service  @relation(fields: [serviceId], references: [id])
  slotId               String
  slot                 TimeSlot @relation(fields: [slotId], references: [id])
  addOns               String[]
  customerName         String
  customerPhone        String
  carMake              String
  carModel             String
  carYear              Int
  carColour            String
  registrationNumber   String
  fuelType             String
  deliveryType         String
  pickupAddress        String?
  totalAmountPaise     Int
  depositPaise         Int
  balancePaise         Int
  paymentStatus        String   @default("pending")
  phonepeTransactionId String?
  status               String   @default("confirmed")
  adminNotes           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
